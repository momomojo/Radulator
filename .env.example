# Google Analytics 4 Configuration
# Copy this file to .env and add your actual Measurement ID

# Get your GA4 Measurement ID from:
# 1. Go to https://analytics.google.com
# 2. Admin → Data Streams → Web Stream
# 3. Copy the Measurement ID (format: G-XXXXXXXXXX)

VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console + Bing Webmaster Tools verification
# Paste only the `content` token from each dashboard-provided meta tag.
VITE_GOOGLE_SITE_VERIFICATION=
VITE_BING_SITE_VERIFICATION=

# Optional one-paste fallback if a dashboard gives full meta tags instead of tokens.
# Allowlisted to google-site-verification + msvalidate.01 meta tags only.
VITE_SEARCH_VERIFICATION_META=
