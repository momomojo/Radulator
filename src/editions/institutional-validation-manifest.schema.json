{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radulator.invalid/schemas/institutional-validation-manifest.schema.json",
  "title": "Radulator Institutional validation manifest",
  "description": "Private implementation gate. Schema validity is necessary but not sufficient; the cross-file fail-closed invariants in the fan-in packet are also mandatory.",
  "type": "array",
  "maxItems": 12,
  "uniqueItems": true,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "stable_id",
      "display_name",
      "component_path",
      "repo_sha",
      "implemented_version",
      "formula_source_citations",
      "inputs",
      "rounding",
      "outputs",
      "limitations",
      "existing_test_files",
      "existing_vectors",
      "missing_vectors",
      "independent_recomputation",
      "reviewer_status",
      "emergency_disable_identifier",
      "allowed_in_institutional"
    ],
    "properties": {
      "stable_id": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "display_name": {
        "type": "string",
        "minLength": 1
      },
      "component_path": {
        "type": "string",
        "pattern": "^src/components/calculators/.+\\.jsx$"
      },
      "repo_sha": {
        "type": "string",
        "pattern": "^[a-f0-9]{40}$"
      },
      "implemented_version": {
        "type": "string",
        "minLength": 1
      },
      "formula_source_citations": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_id",
            "title",
            "url",
            "locator",
            "claim"
          ],
          "properties": {
            "source_id": {
              "type": "string",
              "minLength": 1
            },
            "title": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "pattern": "^https://"
            },
            "locator": {
              "type": "string",
              "minLength": 1
            },
            "claim": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "inputs": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "label",
            "unit",
            "range"
          ],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]*$"
            },
            "label": {
              "type": "string",
              "minLength": 1
            },
            "unit": {
              "type": [
                "string",
                "null"
              ]
            },
            "range": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "minimum": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "maximum": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "allowed_values": {
                  "type": "array",
                  "items": {
                    "type": [
                      "string",
                      "number",
                      "boolean"
                    ]
                  },
                  "minItems": 1,
                  "uniqueItems": true
                },
                "range_basis": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "range_basis"
              ],
              "anyOf": [
                {
                  "required": [
                    "minimum"
                  ],
                  "properties": {
                    "minimum": {
                      "type": "number"
                    }
                  }
                },
                {
                  "required": [
                    "maximum"
                  ],
                  "properties": {
                    "maximum": {
                      "type": "number"
                    }
                  }
                },
                {
                  "required": [
                    "allowed_values"
                  ],
                  "properties": {
                    "allowed_values": {
                      "type": "array",
                      "minItems": 1
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "rounding": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "output_id",
            "method",
            "precision",
            "stage"
          ],
          "properties": {
            "output_id": {
              "type": "string",
              "minLength": 1
            },
            "method": {
              "enum": [
                "none",
                "fixed-decimal",
                "nearest-integer",
                "significant-figures",
                "source-specified"
              ]
            },
            "precision": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "stage": {
              "enum": [
                "intermediate",
                "final-output",
                "both",
                "not-applicable"
              ]
            }
          }
        }
      },
      "outputs": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "label",
            "unit",
            "value_type"
          ],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]*$"
            },
            "label": {
              "type": "string",
              "minLength": 1
            },
            "unit": {
              "type": [
                "string",
                "null"
              ]
            },
            "value_type": {
              "enum": [
                "number",
                "string",
                "classification",
                "structured"
              ]
            }
          }
        }
      },
      "limitations": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "existing_test_files": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "existing_vectors": {
        "type": "array",
        "minItems": 4,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "vector_id",
            "class",
            "inputs",
            "expected_outputs",
            "source_or_derivation",
            "test_location"
          ],
          "properties": {
            "vector_id": {
              "type": "string",
              "minLength": 1
            },
            "class": {
              "enum": [
                "low",
                "mid",
                "high",
                "edge"
              ]
            },
            "inputs": {
              "type": "object",
              "minProperties": 1
            },
            "expected_outputs": {
              "type": "object",
              "minProperties": 1
            },
            "source_or_derivation": {
              "type": "string",
              "minLength": 1
            },
            "test_location": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "allOf": [
          {
            "contains": {
              "type": "object",
              "properties": {
                "class": {
                  "const": "low"
                }
              },
              "required": [
                "class"
              ]
            }
          },
          {
            "contains": {
              "type": "object",
              "properties": {
                "class": {
                  "const": "mid"
                }
              },
              "required": [
                "class"
              ]
            }
          },
          {
            "contains": {
              "type": "object",
              "properties": {
                "class": {
                  "const": "high"
                }
              },
              "required": [
                "class"
              ]
            }
          },
          {
            "contains": {
              "type": "object",
              "properties": {
                "class": {
                  "const": "edge"
                }
              },
              "required": [
                "class"
              ]
            }
          }
        ]
      },
      "missing_vectors": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "independent_recomputation": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "artifact",
          "artifact_sha256",
          "checked_at",
          "vector_ids"
        ],
        "properties": {
          "status": {
            "const": "PASS"
          },
          "artifact": {
            "type": "string",
            "minLength": 1
          },
          "artifact_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "checked_at": {
            "type": "string",
            "format": "date"
          },
          "vector_ids": {
            "type": "array",
            "minItems": 4,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "reviewer_status": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rights",
          "regulatory",
          "source_math",
          "clinical",
          "unresolved_holds"
        ],
        "properties": {
          "rights": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "artifact",
              "artifact_sha256"
            ],
            "properties": {
              "status": {
                "const": "GREEN"
              },
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "artifact_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          },
          "regulatory": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "artifact",
              "artifact_sha256"
            ],
            "properties": {
              "status": {
                "const": "lower-risk transparent reference candidate"
              },
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "artifact_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          },
          "source_math": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "artifact",
              "artifact_sha256"
            ],
            "properties": {
              "status": {
                "const": "PASS"
              },
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "artifact_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          },
          "clinical": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "reviewer",
              "review_date",
              "artifact",
              "artifact_sha256"
            ],
            "properties": {
              "status": {
                "const": "APPROVED"
              },
              "reviewer": {
                "const": "Mohib Hafeez, MD"
              },
              "review_date": {
                "type": "string",
                "format": "date"
              },
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "artifact_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          },
          "unresolved_holds": {
            "type": "array",
            "maxItems": 0
          }
        }
      },
      "emergency_disable_identifier": {
        "type": "string",
        "pattern": "^calculator:[a-z][a-z0-9-]*$"
      },
      "allowed_in_institutional": {
        "const": true
      }
    }
  }
}
