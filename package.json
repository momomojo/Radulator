{
  "name": "radcalc-2.0",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/update-about.mjs && node scripts/generate-edition-artifacts.mjs",
    "build": "vite build",
    "build:public": "RADULATOR_EDITION=public npm run build",
    "build:institutional": "RADULATOR_EDITION=institutional npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "vite build && gh-pages -d dist",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:smoke": "npm run build && playwright test tests/e2e/smoke",
    "test:calculator": "playwright test tests/e2e/calculators",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:compute": "node --import ./scripts/register-jsx-loader.mjs scripts/run-compute-tests.mjs",
    "test:search-verification": "node tests/search-verification-meta.test.mjs && node tests/ping-search-indexes.test.mjs",
    "test:invariants": "node scripts/check-radulator-invariants.test.mjs",
    "test:edition": "node tests/edition-resolution.test.mjs",
    "test:dev-local": "bash tests/scripts/dev-local-restart.sh",
    "test:decompose-full-suite": "node scripts/full-suite-decomposer.mjs",
    "check:invariants": "node scripts/check-radulator-invariants.mjs",
    "check:edition": "node scripts/check-edition-invariants.mjs",
    "test:institutional-network": "node scripts/run-institutional-network-test.mjs",
    "metrics:loops": "node scripts/collect-loop-metrics.mjs",
    "proof:feature": "node scripts/capture-feature-proof.mjs",
    "index:ping": "node scripts/ping-search-indexes.mjs",
    "index:ping:dry-run": "node scripts/ping-search-indexes.mjs --dry-run"
  },
  "dependencies": {
    "@formspree/react": "^3.0.0",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.526.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.56.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "gh-pages": "^6.3.0",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^7.0.4"
  }
}
